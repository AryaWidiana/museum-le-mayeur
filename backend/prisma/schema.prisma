// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  name       String?  @default("Admin Museum")
  profilePic String?
  role       String   @default("admin")
  createdAt  DateTime @default(now())
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // WNI / WNA
  price     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@unique([name, type])
}

model Transaction {
  id         Int      @id @default(autoincrement())
  name       String
  totalPrice Int
  payment    String   @default("Tunai") // Tunai / QRIS
  createdAt  DateTime @default(now())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  type      String   // login, edit, export, add, transaction
  title     String
  detail    String
  createdAt DateTime @default(now())
}

model AdminActivity {
  id        Int      @id @default(autoincrement())
  date      DateTime
  desc      String
  status    String   // hadir, libur, tutup
  createdAt DateTime @default(now())
}

model Schedule {
  id        Int      @id @default(autoincrement())
  openTime  DateTime
  closeTime DateTime
}
